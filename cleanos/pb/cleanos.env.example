# CleanOS — variáveis de ambiente (exemplo)
# Copie para /opt/cleanos/cleanos.env e preencha com os valores reais.
# NUNCA versione o arquivo com valores reais.
# Permissão recomendada: chmod 600 /opt/cleanos/cleanos.env
# Dono recomendado:      chown cleanos:cleanos /opt/cleanos/cleanos.env

# URL base do servidor UAZAPI (sem barra final)
UAZAPI_BASE_URL=https://appexcrm.uazapi.com

# Token de administrador do UAZAPI (obtido no painel UAZAPI)
UAZAPI_ADMIN_TOKEN=seu_admin_token_aqui

# URL do webhook do n8n que recebe a notificação quando uma OS é concluída,
# dispara a enquete de avaliação e grava o resultado de volta.
# Deixe vazio para desabilitar o gatilho (OS conclui normalmente sem avaliação).
N8N_RATING_WEBHOOK_URL=

# Segredo compartilhado entre PocketBase e n8n para autenticar os endpoints de serviço
# (/api/cleanos/ratings/ingest e /api/cleanos/ratings/pending).
# Use uma string aleatória longa (mínimo 32 chars). Configure o mesmo valor no n8n.
# Se não configurado, os endpoints de serviço retornam 401 em TODOS os requests.
CLEANOS_SERVICE_SECRET=
